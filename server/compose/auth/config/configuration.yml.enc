# yaml-language-server: $schema=https://www.authelia.com/schemas/latest/json-schema/configuration.json
theme: auto
log:
    level: info
identity_providers:
    oidc:
        hmac_secret: ENC[AES256_GCM,data:vNeiUALC09tHhUDSSq+TbFCqQ1Dn7bnBSvZnBt++RGIf2tYNIaPOQ18X/p6mZgt8lR8XiO1+Nvuxtdr+amYsjvAQYNulGE/YrHlwmm/BP+m4aPSXQTbavNBDxGeZCUaszQsTpBZkZE+jrFa/MyarQmJrbu9QRXeNA38QGNRLDsU=,iv:7QZgXaUEzm8qifX8Q47V2HAn0WCGTHvd/dzTg5HamsE=,tag:9TaVcIjImwlqpay5hiP6CQ==,type:str]
        jwks:
            - key_id: main
              algorithm: RS256
              use: sig
              key: ENC[AES256_GCM,data:,iv:NKN1jc3yQAtRhiokd2tI1jUoFyXGd5r5l3Ckuzoil5g=,tag:pjSRIQj5GFTa0Y72SKgdvA==,type:str]
        clients:
            - client_id: ENC[AES256_GCM,data:GIOcH3UnTfDcXsg8XQ9jgP9sg1AZazdaSHEbMtyzqJiPc0KGmXq/+fmHOQUjmsVSwiYXu6OTDxukSNwrjKhGQG092t6RPugF,iv:GFSORTYOtSIAmj2whjCL9kf15mVwoPoko2E7h7UIFus=,tag:DSwHze/pM1XkaqovbKoM3Q==,type:str]
              client_name: Wakapi
              client_secret: ENC[AES256_GCM,data:aVdKb8SahAWWUB8TOXcqufdOJow/zFvrEeuVJ1iazf3afGqAQUXS6dj2azYmGK5yh02zY2bcEAkulk7IjM1kiPi1S0XQhMzAyM9csL0tZ22DoqtKvWwbYW9rG1fpMI8scZVXr5TBOjJaA0b+kgtxNF9XfpCjvTeGbWSp6DO+tiR/cZA=,iv:SyjYJlvocyiX4EGYivSINFRc8/zBuzHEfhRbkf3gnrA=,tag:7wGdD1G2IigPZh7KsoNebQ==,type:str]
              public: false
              authorization_policy: one_factor
              redirect_uris:
                - https://waka.lxft.dev/oidc/authelia/callback
              scopes:
                - openid
                - profile
                - email
              grant_types:
                - authorization_code
              response_types:
                - code
              token_endpoint_auth_method: client_secret_basic
              userinfo_signed_response_alg: none
server:
    address: tcp://0.0.0.0:9091
    endpoints:
        authz:
            forward-auth:
                implementation: ForwardAuth
session:
    name: authelia_session
    same_site: lax
    inactivity: 5m
    expiration: 1h
    remember_me: 1M
    cookies:
        - domain: lxft.dev
          authelia_url: https://auth.lxft.dev
          default_redirection_url: https://lxft.dev
regulation:
    max_retries: 3
    find_time: 2m
    ban_time: 5m
storage:
    postgres:
        address: tcp://authelia-db:5432
        database: authelia
        username: postgres
notifier:
    disable_startup_check: true
    smtp:
        address: smtp://smtp.maileroo.com:587
        username: auth@lxft.dev
        sender: Authelia <auth@lxft.dev>
        identifier: localhost
        startup_check_address: auth@lxft.dev
authentication_backend:
    file:
        path: /config/users_database.yml
        password:
            algorithm: argon2
access_control:
    default_policy: deny
    rules:
        - domain: auth.lxft.dev
          policy: bypass
        - domain: music.lxft.dev
          resources:
            - ^/rest/.*
            - ^/share/.*
          policy: bypass
        - domain: music.lxft.dev
          subject:
            - group:admins
          policy: one_factor
        - domain: waka.lxft.dev
          resources:
            - ^/api/.*
          policy: bypass
        - domain: waka.lxft.dev
          subject:
            - group:admins
          policy: one_factor
sops:
    age:
        - recipient: age13vz3u6zjv44a4ak4r2qmdaydh4s0l4yfhywhsvzzhg9p5rn004pqsy8gx3
          enc: |
            -----BEGIN AGE ENCRYPTED FILE-----
            YWdlLWVuY3J5cHRpb24ub3JnL3YxCi0+IFgyNTUxOSBNeEtYcDhmbVY0cVJtNFll
            UEkrSFpuYXE5VDZRUlBEZk4yeHkzRG0wbFVVCjZoa0F3L29FNFl1ZVJEckJlWHhP
            SUFNZEw4RHVZeGdkN1JKUEROai83VXMKLS0tIGhTUXVkSDduOVBvcU1TMmMwWDQ5
            a3ZiNi9kd0pGVm9MMHlTaFFmWU5aanMKPkIXyrLQ4RT3G4eCXtDsrGhzsERhT3UZ
            ByPDWKXX66hYax5tpC1XstALr8KPlQAD9oo9t2YVMwVX7YUYoCVpRA==
            -----END AGE ENCRYPTED FILE-----
