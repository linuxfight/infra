# yaml-language-server: $schema=https://www.authelia.com/schemas/latest/json-schema/configuration.json
theme: auto
log:
    level: info
identity_providers:
    oidc:
        claims_policies:
            tuwunel:
                id_token:
                    - email
                    - name
                    - groups
                    - preferred_username
        hmac_secret: ENC[AES256_GCM,data:dNyv5n+POgxD9ATFZWjMVW7/vFOoQ79L1PRGxpEc5Y1HZA0N4fyAtwGoWweuBmb3lkPhyDmTyFoIa7U/5bGZIQnLIm6A7HNx8KjZrBY9kuAK4dJqSuC2Z8moZrRLZjh5zTuhcfL7g8oZmsEkEwRM/7VUccoEj6AGb0CeUZc8C4g=,iv:+KD2p+8qrKVLg/y4O9CimlSu1XYNGNO3pqqNWOO6LTY=,tag:BbJOcK/ANixQ7FllXp83oA==,type:str]
        jwks:
            - key_id: main
              algorithm: RS256
              use: sig
              key: ENC[AES256_GCM,data:,iv:katla1JRAMuoeh0HyDpfYbymNvd25E3mWs++2oxLT84=,tag:zKwU8hwCIUqmALXhV+J9gg==,type:str]
        clients:
            - client_id: ENC[AES256_GCM,data:WAiDkai5ZA4HBITKysiNwoWkOjAgDzD+wAokBzZGRSvIKBU3LUlQw/poVudc+BKCQ313h/bKJc4r8yrkIPjzXXSLoFTSMpMO,iv:TvQIXK0UeIYEs4zU/t3LIhUWsnNdFi1VXPVbSVcqn3U=,tag:Ika4UVorvTOuV3qezPghbA==,type:str]
              client_name: Wakapi
              client_secret: ENC[AES256_GCM,data:Hf5kI+AVFFC3u1QrrU+ugMfU/qP/7Lq4OIPob6eFB4ywAbxqNKtPfxIxn7iTisF4x97cSCTtifZKh+F8+6c8xh9lS0TdWXOko8heQQPdKmtqo4k8OsVtZNH1s/LKJSdSkxGxejaunU8QmXjkt610xJJdrRYQY+WGDbc8Pm+LmOheYFA=,iv:zlzt8N+8JQRvMJelue+EGshmyC3cwgtJSthyV4940pQ=,tag:f/wP//rnpjo3NJu6E+HbgQ==,type:str]
              public: false
              authorization_policy: one_factor
              redirect_uris:
                - https://waka.lxft.dev/oidc/authelia/callback
              scopes:
                - openid
                - profile
                - email
              grant_types:
                - authorization_code
              response_types:
                - code
              token_endpoint_auth_method: client_secret_basic
              userinfo_signed_response_alg: none
            - client_id: ENC[AES256_GCM,data:FDmLOe9DK6aCzgonNVX/IVCraEpLEotg0ykP1Ia+425PulMMsa2f5h7tm1lKEOF0JFf0pjjxaCT865bsnl7a2TerZom41gY3,iv:kRhdjoQDvtNZXJXvbaeJNTuECyQ5JoqE2h49x+pgVpk=,tag:IXCdyVFbhNvmDpQz4Zt2hQ==,type:str]
              client_name: tuwunel
              client_secret: ENC[AES256_GCM,data:MD24xJGd1RSIsAO3j+ZrHBuY+0WNP394PWpQJbnEEEf+yfn5oWywPl6E2BeKHrYmHEO8DYL0S0PRJuSZkSwLUCVOpHBvWkVWK4Pvgy7HFHqFEVoz2kKM0dpczLnK8AzPqtqJL02nE7NF9fYdX4gfGOoX+9TLV98FjLYgr/ptUHgC5hc=,iv:Ps9Bk+9uOJExdW90Sn1rrJEKVf9RO/kRE0jZRo4q2oY=,tag:FNzrO0+9cDu1tliihguTVg==,type:str]
              claims_policy: tuwunel
              public: false
              redirect_uris:
                - https://chat.lxft.dev/_matrix/client/unstable/login/sso/callback/3yTumYA6pk12O5oCiz6tV3V3XwynSau0M1KUwry8E3Mtw91bUhx.M2qCaiHcHZOGhZqUZX8I
              scopes:
                - openid
                - groups
                - email
                - profile
              grant_types:
                - refresh_token
                - authorization_code
              response_types:
                - code
              response_modes:
                - form_post
              token_endpoint_auth_method: client_secret_post
server:
    address: tcp://0.0.0.0:9091
    endpoints:
        authz:
            forward-auth:
                implementation: ForwardAuth
session:
    name: authelia_session
    same_site: lax
    inactivity: 24h
    expiration: 24h
    remember_me: 8760h
    cookies:
        - domain: lxft.dev
          authelia_url: https://auth.lxft.dev
          default_redirection_url: https://lxft.dev
regulation:
    max_retries: 3
    find_time: 2m
    ban_time: 5m
storage:
    postgres:
        address: tcp://authelia-db:5432
        database: authelia
        username: postgres
notifier:
    disable_startup_check: true
    smtp:
        address: smtp://smtp.maileroo.com:587
        username: auth@lxft.dev
        sender: Authelia <auth@lxft.dev>
        identifier: localhost
        startup_check_address: auth@lxft.dev
authentication_backend:
    file:
        path: /config/users_database.yml
        password:
            algorithm: argon2
access_control:
    default_policy: deny
    rules:
        - domain: auth.lxft.dev
          policy: bypass
        - domain: music.lxft.dev
          resources:
            - ^/rest/.*
            - ^/share/.*
          policy: bypass
        - domain: music.lxft.dev
          subject:
            - group:admins
          policy: one_factor
        - domain: waka.lxft.dev
          resources:
            - ^/api/.*
          policy: bypass
        - domain: waka.lxft.dev
          subject:
            - group:admins
          policy: one_factor
sops:
    age:
        - recipient: age13vz3u6zjv44a4ak4r2qmdaydh4s0l4yfhywhsvzzhg9p5rn004pqsy8gx3
          enc: |
            -----BEGIN AGE ENCRYPTED FILE-----
            YWdlLWVuY3J5cHRpb24ub3JnL3YxCi0+IFgyNTUxOSBuUFI0bDlNR2pjMFZ1WGJK
